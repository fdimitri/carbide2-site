---
import Base from './Base.astro';
import RelatedPosts from '@/components/site/RelatedPosts.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, heroImage } = post.data;
const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const updated = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const editUrl = `https://github.com/fdimitri/carbide2-site/edit/main/src/content/blog/${post.id}`;

const canonical = new URL(`/blog/${post.slug}`, Astro.site).toString();
const ogImage = new URL(heroImage ?? '/og-default.png', Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'CARBIDE',
    logo: { '@type': 'ImageObject', url: new URL('/og-default.png', Astro.site).toString() },
  },
  image: ogImage,
  url: canonical,
  mainEntityOfPage: canonical,
  ...(tags && tags.length > 0 && { keywords: tags.join(', ') }),
};
---

<Base
  title={`${title} — CARB/IDE2 devblog`}
  description={description}
  image={heroImage ?? '/og-default.png'}
  type="article"
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: updatedDate?.toISOString(),
    author,
    tags,
  }}
  jsonLd={jsonLd}
>
  <article class="container-narrow py-16">
    <header class="mb-10 border-b border-carbide-line pb-8">
      <p class="font-mono text-sm text-carbide-muted">
        <time datetime={pubDate.toISOString()}>{formatted}</time>
        {readingTime && <span class="mx-2 text-carbide-dim">·</span>}
        {readingTime && <span>{readingTime}</span>}
        <span class="mx-2 text-carbide-dim">·</span>
        <span>{author}</span>
      </p>
      <h1 class="mt-3 text-4xl font-bold text-carbide-green glow-text">{title}</h1>
      {description && <p class="mt-3 text-lg text-carbide-muted">{description}</p>}
      {tags && tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {tags.map((t) => (
            <li>
              <a
                href={`/blog/tags/${t}`}
                class="inline-block rounded border border-carbide-line bg-carbide-panel px-2 py-0.5 font-mono text-xs text-carbide-muted hover:border-carbide-green hover:text-carbide-green"
              >
                #{t}
              </a>
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="prose-carbide">
      <slot />
    </div>

    <RelatedPosts post={post} />

    <footer class="mt-16 flex flex-col gap-2 border-t border-carbide-line pt-6 font-mono text-sm text-carbide-muted sm:flex-row sm:items-center sm:justify-between">
      {updated && <span>Last updated {updated}</span>}
      <a href={editUrl} rel="noopener" target="_blank">Edit this post on GitHub →</a>
    </footer>
  </article>
</Base>
