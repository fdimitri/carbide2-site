---
import '@/styles/global.css';
import Header from '@/components/site/Header.astro';
import Footer from '@/components/site/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'CARB/IDE2 — a collaborative browser IDE',
  description = 'CARB/IDE2 is an open-source, browser-based collaborative IDE with live terminal sharing, an in-database filesystem, and built-in chat.',
  // Rasterized PNG for full social-platform support (X/Twitter and some
  // scrapers don't render SVG OG images).
  image = '/og-default.png',
  noindex = false,
  type = 'website',
  article,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const cfToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#08090d" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="CARB/IDE2 devblog" href="/rss.xml" />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {type === 'article' && article?.publishedTime && (
      <meta property="article:published_time" content={article.publishedTime} />
    )}
    {type === 'article' && article?.modifiedTime && (
      <meta property="article:modified_time" content={article.modifiedTime} />
    )}
    {type === 'article' && article?.author && (
      <meta property="article:author" content={article.author} />
    )}
    {type === 'article' && article?.tags?.map((t) => (
      <meta property="article:tag" content={t} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    {cfToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfToken}"}`}
      ></script>
    )}
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-carbide-panel focus:px-3 focus:py-2 focus:rounded focus:border focus:border-carbide-green"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
