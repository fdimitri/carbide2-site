---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = Array.from(
  new Set(posts.flatMap((p) => p.data.tags ?? [])),
).sort();
---

<Base title="Devblog — CARB/IDE2" description="Posts from the people building CARB/IDE2.">
  <section class="container-narrow pt-16 pb-8">
    <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// devblog</p>
    <h1 class="mt-2 font-mono text-4xl font-bold text-carbide-text">Build log</h1>
    <p class="mt-3 text-carbide-muted">
      Design notes, debugging stories, and release announcements.
      <a href="/rss.xml" class="ml-1">Subscribe via RSS →</a>
    </p>
    {allTags.length > 0 && (
      <ul class="mt-6 flex flex-wrap gap-2">
        {allTags.map((tag) => (
          <li>
            <a
              href={`/blog/tags/${tag}`}
              class="inline-block rounded border border-carbide-line bg-carbide-panel px-2 py-0.5 font-mono text-xs text-carbide-muted hover:border-carbide-green hover:text-carbide-green"
            >
              #{tag}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="container-narrow pb-24">
    {posts.length === 0 ? (
      <p class="rounded border border-carbide-line bg-carbide-panel/60 p-6 font-mono text-sm text-carbide-muted">
        No posts yet — first one is in the oven.
      </p>
    ) : (
      <ul class="divide-y divide-carbide-line">
        {posts.map((post) => (
          <li class="py-6">
            <a href={`/blog/${post.slug}`} class="group block">
              <p class="font-mono text-xs text-carbide-muted">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <span class="mx-2 text-carbide-dim">·</span>
                <span>{post.data.author}</span>
              </p>
              <h2 class="mt-1 font-mono text-xl text-carbide-green group-hover:glow-text">
                {post.data.title}
              </h2>
              <p class="mt-2 text-carbide-muted">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>
