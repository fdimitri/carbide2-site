---
import Base from '@/layouts/Base.astro';

const email = 'frankd@carbidecore.online';
---

<Base
  title="Contact — CARB/IDE2"
  description="Get in touch with the CARB/IDE2 project — send a note or email frankd@carbidecore.online."
>
  <div class="container-narrow py-16">
    <header class="mb-8">
      <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// contact</p>
      <h1 class="mt-2 text-2xl font-bold text-carbide-text">Get in touch</h1>
      <p class="mt-3 text-carbide-muted">
        Questions, bug reports, or just want to say hi? Drop a note below or
        reach out directly.
      </p>
    </header>

    <!-- Direct contact info -->
    <dl class="mb-10 grid gap-4 font-mono text-sm sm:grid-cols-2">
      <div class="rounded-lg border border-carbide-line bg-carbide-surface/70 px-5 py-4">
        <dt class="text-xs uppercase tracking-widest text-carbide-amber">Email</dt>
        <dd class="mt-1">
          <a href={`mailto:${email}`} class="text-carbide-green hover:underline">{email}</a>
        </dd>
      </div>
      <div class="rounded-lg border border-carbide-line bg-carbide-surface/70 px-5 py-4">
        <dt class="text-xs uppercase tracking-widest text-carbide-amber">GitHub</dt>
        <dd class="mt-1">
          <a
            href="https://github.com/fdimitri/carbide2"
            rel="noopener"
            target="_blank"
            class="text-carbide-green hover:underline"
          >
            github.com/fdimitri/carbide2 ↗
          </a>
        </dd>
      </div>
    </dl>

    <!-- Contact form: progressively enhanced to open the user's mail client
         pre-filled. Works with zero backend on static hosting; swap the submit
         handler for a real endpoint (Pages Function / form service) later. -->
    <form id="contact-form" class="space-y-5" novalidate>
      <div>
        <label for="cf-name" class="block font-mono text-xs uppercase tracking-widest text-carbide-amber">
          Name
        </label>
        <input
          id="cf-name"
          name="name"
          type="text"
          autocomplete="name"
          class="mt-2 w-full rounded-md border border-carbide-line bg-carbide-panel px-3 py-2 font-mono text-sm text-carbide-text placeholder:text-carbide-muted focus:border-carbide-green/60 focus:outline-none"
          placeholder="Ada Lovelace"
        />
      </div>

      <div>
        <label for="cf-email" class="block font-mono text-xs uppercase tracking-widest text-carbide-amber">
          Your email
        </label>
        <input
          id="cf-email"
          name="email"
          type="email"
          autocomplete="email"
          required
          class="mt-2 w-full rounded-md border border-carbide-line bg-carbide-panel px-3 py-2 font-mono text-sm text-carbide-text placeholder:text-carbide-muted focus:border-carbide-green/60 focus:outline-none"
          placeholder="you@example.com"
        />
      </div>

      <div>
        <label for="cf-message" class="block font-mono text-xs uppercase tracking-widest text-carbide-amber">
          Message
        </label>
        <textarea
          id="cf-message"
          name="message"
          rows="6"
          required
          class="mt-2 w-full rounded-md border border-carbide-line bg-carbide-panel px-3 py-2 font-mono text-sm text-carbide-text placeholder:text-carbide-muted focus:border-carbide-green/60 focus:outline-none"
          placeholder="What's on your mind?"></textarea>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-carbide-green px-4 py-2 font-mono text-sm font-medium text-carbide-bg transition-all hover:bg-carbide-greenDark hover:shadow-glow"
        >
          Send message
        </button>
        <p id="cf-status" class="font-mono text-xs text-carbide-muted" role="status" aria-live="polite"></p>
      </div>
    </form>
  </div>

  <script define:vars={{ email }}>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('cf-status');

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const name = form.elements.name.value.trim();
      const from = form.elements.email.value.trim();
      const message = form.elements.message.value.trim();

      if (!from || !message) {
        status.textContent = 'Please add your email and a message.';
        return;
      }

      const subject = `[carbidecore] Message${name ? ` from ${name}` : ''}`;
      const body = `${message}\n\n— ${name || 'Anonymous'}${from ? ` <${from}>` : ''}`;
      const href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      window.location.href = href;
      status.textContent = 'Opening your mail client…';
    });
  </script>
</Base>
