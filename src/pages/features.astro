---
import Base from '@/layouts/Base.astro';
import Badge from '@/components/ui/Badge.astro';

const sections = [
  {
    badge: '▶ editor',
    title: 'Browser IDE',
    body:
      'Open a workspace and edit immediately. No installs, no toolchain drift, no machine to provision. Files, terminals, and collaborators all in the same tab.',
  },
  {
    badge: '⏚ pty',
    title: 'Live terminal sharing',
    body:
      'Every terminal is a real PTY on the server, streamed over WebSockets. Multiple people can watch the same shell, and any of them can type. Perfect for pairing, code reviews, or showing a stubborn bug to a teammate.',
  },
  {
    badge: '◉ fs',
    title: 'In-database filesystem',
    body:
      'Files live in Postgres, not on a host disk. That means versioning is cheap, change events are SQL-native, and replicating a workspace is a database operation. INOTIFY-style notifications fan out to every connected client.',
  },
  {
    badge: '⌬ chat',
    title: 'IRC-style chat',
    body:
      'Each project has channels with persistent history. Replies thread, code blocks render with syntax highlighting, and `@mentions` light up the right people. No Slack tab required.',
  },
  {
    badge: '⚙ git',
    title: 'Git integration',
    body:
      'Clone from any remote, branch, commit, and push without leaving the workspace. Your auth, your remote — CARB/IDE2 just runs the porcelain for you.',
  },
  {
    badge: '⌖ webrtc',
    title: 'Voice & video (planned)',
    body:
      'WebRTC audio/video for the same crew already in your shell and chat. Roadmap, not shipped — follow the devblog for updates.',
  },
];
---

<Base title="Features — CARB/IDE2" description="A tour of what CARB/IDE2 does today and what's on the roadmap.">
  <section class="container-narrow pt-16 pb-8">
    <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// features</p>
    <h1 class="mt-2 font-mono text-4xl font-bold text-carbide-text">
      Everything in one tab.
    </h1>
    <p class="mt-4 text-lg text-carbide-muted">
      CARB/IDE2 puts the editor, terminal, filesystem, and chat on the server so
      collaborators see the same state in real time.
    </p>
  </section>

  <section class="container-narrow pb-24">
    <ol class="space-y-12">
      {sections.map((s) => (
        <li class="rounded-lg border border-carbide-line bg-carbide-surface/70 p-6">
          <Badge tone="green">{s.badge}</Badge>
          <h2 class="mt-3 font-mono text-2xl text-carbide-green">{s.title}</h2>
          <p class="mt-3 text-carbide-muted">{s.body}</p>
        </li>
      ))}
    </ol>
  </section>
</Base>
