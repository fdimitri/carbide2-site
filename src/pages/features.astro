---
import Base from '@/layouts/Base.astro';
import Badge from '@/components/ui/Badge.astro';

const sections = [
  {
    badge: '▶ editor',
    title: 'Collaborative Monaco editor',
    body:
      'Open a workspace and edit immediately — no installs, no toolchain drift, no machine to provision. The editor is real-time co-editing: edits from other people apply live in your buffer, and each collaborator gets a named, colored cursor tracked right in the gutter. Files, terminals, and teammates all share one tab.',
  },
  {
    badge: '⏺ pty',
    title: 'Live terminal sharing',
    body:
      'Every terminal is a real PTY on the server, streamed over WebSockets. Multiple people can watch the same shell, and any of them can type. Perfect for pairing, code reviews, or showing a stubborn bug to a teammate.',
  },
  {
    badge: '⏺︎ rec',
    title: 'Terminal session recordings',
    body:
      'Record any terminal to a standard asciinema v2 .cast file with one click, then replay it later — in the UI or with `asciinema play`. Great for capturing a repro, documenting a deploy, or reviewing what a long-running process actually did.',
  },
  {
    badge: '◉ fs',
    title: 'In-database filesystem',
    body:
      'Files live in Postgres, not on a host disk. That means versioning is cheap, change events are SQL-native, and replicating a workspace is a database operation. INOTIFY-style notifications fan out to every connected client.',
  },
  {
    badge: '⌬ chat',
    title: 'IRC-style chat',
    body:
      'Each project has channels with persistent history. Replies thread, code blocks render with syntax highlighting, and `@mentions` light up the right people. No Slack tab required.',
  },
  {
    badge: '⚙ git',
    title: 'Git integration',
    body:
      'Clone from any remote, branch, commit, and push without leaving the workspace. Your auth, your remote — CARB/IDE2 just runs the porcelain for you.',
  },
  {
    badge: '⌖ webrtc',
    title: 'Voice & video',
    body:
      'WebRTC audio/video for the same crew already in your shell and chat. Roughly as built-out as everything else here — it works today, rough edges and all.',
  },
  {
    badge: '✦ agent',
    title: 'AI agent harness',
    body:
      'A first-class agent for plan, chat, and review — not a side panel bolted onto an editor. It connects directly to the same PTYs and in-database filesystem as everyone else, so it runs real commands, watches their output, and edits files in the live workspace. Tool calls flow through the worker alongside human input, which means the agent and your team share one source of truth.',
  },
  {
    badge: '☸ k8s',
    title: 'Kubernetes-native scaling',
    body:
      'A cluster-wide control plane runs a Kubernetes operator that spawns a dedicated workspace pod per project. Workspaces scale out horizontally across nodes, stay isolated from one another, and can be torn down when idle — the whole thing is built to run as a fleet, not a single box.',
  },
];
---

<Base title="Features — CARB/IDE2" description="A tour of what CARB/IDE2 does today and what's on the roadmap.">
  <section class="container-narrow pt-16 pb-8">
    <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// features</p>
    <h1 class="mt-2 font-mono text-4xl font-bold text-carbide-text">
      Everything in one tab.
    </h1>
    <p class="mt-4 text-lg text-carbide-muted">
      CARB/IDE2 puts the editor, terminal, filesystem, and chat on the server so
      collaborators see the same state in real time.
    </p>
  </section>

  <section class="container-wide pb-24">
    <ol class="grid items-start gap-6 md:grid-cols-2">
      {sections.map((s) => (
        <li class="rounded-lg border border-carbide-line bg-carbide-surface/70 p-6">
          <Badge tone="green">{s.badge}</Badge>
          <h2 class="mt-3 font-mono text-2xl text-carbide-green">{s.title}</h2>
          <p class="mt-3 text-carbide-muted">{s.body}</p>
        </li>
      ))}
    </ol>
  </section>
</Base>
