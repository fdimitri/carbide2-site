---
import Base from '@/layouts/Base.astro';
import TerminalHero from '@/components/site/TerminalHero.astro';
import FeatureGrid from '@/components/site/FeatureGrid.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import { getCollection } from 'astro:content';

const features = [
  {
    icon: '▶',
    title: 'Browser IDE',
    body: 'A full editor in your tab. No installs, no "works on my machine" — your workspace lives on the server, not your laptop.',
  },
  {
    icon: '⏚',
    title: 'Live PTY sharing',
    body: 'Real terminals, mirrored to every collaborator in real time. Team up on a bug or screen-share a long-running process. Record sessions for later playback.',
  },
  {
    icon: '◉',
    title: 'In-database filesystem',
    body: 'Files live in Postgres with INOTIFY-driven change events. Yeah, we log every single keystroke. Don\'t worry, it\'s encrypted at rest and in transit. Or atleast, that\'s what Claude believes.',
  },
  {
    icon: '⌬',
    title: 'IRC-style chat',
    body: 'Per-project channels with persistent history. Built-in, not bolted on.',
  },
  {
    icon: '⚙',
    title: 'Git integration',
    body: 'Clone, branch, commit and push from inside the workspace. Your projects, your remote.',
  },
  {
    icon: '⌖',
    title: 'WebRTC',
    body: 'Voice and video for the same collaborators already in your terminal and chat.',
  },
];

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base>
  <section class="container-wide pt-16 pb-12 lg:pt-24">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <Badge tone="amber">v0 · tech demo</Badge>
        <h1 class="mt-4 font-mono text-4xl font-bold leading-tight text-carbide-text sm:text-5xl">
          The collaborative IDE
          <span class="block text-carbide-green glow-text">that lives on the server.</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg text-carbide-muted">
          CARB/IDE2 is an open-source browser IDE with a real shared terminal, an
          in-database filesystem, and chat baked in. Built on Ruby and Rails 8.1, Vue 3, and Postgres, it's designed for teams who want to collaborate without the friction of local setups. It's currently a tech demo, but the code is open and
          licensed GPLv3.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <Button href="https://github.com/fdimitri/carbide2-server" external>
            View on GitHub →
          </Button>
          <Button href="/features" variant="ghost">Tour the features</Button>
        </div>
      </div>

      <TerminalHero />
    </div>
  </section>

  <section class="container-wide py-8">
    <div class="rounded-lg border border-carbide-line bg-carbide-surface/70 px-8 py-6 text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// what is carb/ide?</p>
      <p class="mt-3 text-carbide-muted"><span class="font-mono text-carbide-text">CARB/IDE</span> is…</p>
      <p id="carbide-acronym" class="mt-2 font-mono text-lg text-carbide-green glow-text" style="opacity:1;transition:opacity 0.5s ease"></p>
    </div>
  </section>

  <section class="container-wide py-16">
    <header class="mb-8">
      <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// features</p>
      <h2 class="mt-2 text-2xl font-bold text-carbide-text">Why it's different</h2>
    </header>
    <FeatureGrid features={features} />
  </section>

  <section class="container-wide py-16">
    <header class="mb-8">
      <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// architecture</p>
      <h2 class="mt-2 text-2xl font-bold text-carbide-text">Four moving parts</h2>
    </header>
    <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { n: '01', title: 'control', body: 'The only cluster-wide Rails process. Owns users, projects, JWT minting, and the Kubernetes operator that spawns workspace pods.' },
        { n: '02', title: 'server', body: 'Per-project workspace pod. Rails REST API + Postgres-backed VFS + asset serving.' },
        { n: '03', title: 'worker', body: 'EventMachine WebSocket server inside each workspace pod. Owns PTY shells, real-time file sync, chat, LLM agent tool calls.' },
        { n: '04', title: 'client', body: 'Vue 3 + Vite SPA with Monaco editor and xterm.js. Shipped into both the workspace and the control dashboard.' },
      ].map((s) => (
        <li class="rounded-lg border border-carbide-line bg-carbide-surface/70 p-5">
          <p class="font-mono text-2xl text-carbide-green glow-text">{s.n}</p>
          <h3 class="mt-2 font-mono text-base text-carbide-text">{s.title}</h3>
          <p class="mt-2 text-sm text-carbide-muted">{s.body}</p>
        </li>
      ))}
    </ol>
  </section>

  {latestPosts.length > 0 && (
    <section class="container-wide py-16">
      <header class="mb-8 flex items-end justify-between">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// devblog</p>
          <h2 class="mt-2 text-2xl font-bold text-carbide-text">Latest from the build log</h2>
        </div>
        <a href="/blog" class="font-mono text-sm">All posts →</a>
      </header>
      <ul class="grid gap-4 sm:grid-cols-3">
        {latestPosts.map((post) => (
          <li class="rounded-lg border border-carbide-line bg-carbide-surface/70 p-5 transition-colors hover:border-carbide-green/50">
            <a href={`/blog/${post.slug}`} class="block">
              <p class="font-mono text-xs text-carbide-muted">
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </p>
              <h3 class="mt-2 font-mono text-base text-carbide-green">{post.data.title}</h3>
              <p class="mt-2 line-clamp-3 text-sm text-carbide-muted">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="container-wide py-16">
    <header class="mb-8">
      <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// screenshot</p>
      <h2 class="mt-2 text-2xl font-bold text-carbide-text">CARB/IDE2 in action (actual, current screenshot)</h2>
    </header>
    <img
      src="/app-screenshot.png"
      alt="CARB/IDE2 screenshot"
      class="w-full rounded-lg border border-carbide-line shadow-lg"
    />
  </section>
</Base>

<script>
  const acronyms = [
    "CARBIDE Ain't Recursive, Bro, I Delete Everything",
    "CARBIDE Ain't Real Because I Don't Even Exist",
    "CARBIDE Ain't Really Built, It's Definitely Experimental",
    // "CARBIDE Ain't Really Broken If Done Eventually",
    "Constantly Arguing, Reviewing, Building, Integrating, Deploying, Evaluating",
    "Collaborative AI Runtime for Building and Iterating on Developer Environments",
    "Commit And Regret: Bug Investigation Done Eventually",
    "Can't Always Run Before I Do Everything",
    "Code Almost Ready, Boss Is Demanding Estimates",
    "Coffee And Ruby Build Infrastructure Development Environments",
    "Continuously Avoiding Real Business Interrupts, Deploying Everything",
    "Can't Always Remember Brackets In Dynamic Environments",  
    "Continuously Adding Ridiculous Bells, Increasingly Doubting Everything",
    "Code And Run... Build? Iterate? Deploy? Erm\u2026",
    "Constantly Adding Random Bits, Increasingly Desperate Engineers",
    "Can't Avoid Rewriting, But Deployment's Expensive",
    "Collaborative Artificial Resource Builder Interface Development Ecosystem",
    "Cloud-Assisted Rapid Build & Integration Deployment Engine",
    // "Collaboratively Assembling Really Beautiful Integrated Developer Experiences",
    // "CARBIDE Automatically Runs Because It Deploys Everywhere",
  ];

  const el = document.getElementById('carbide-acronym');
  let current = Math.floor(Math.random() * acronyms.length);
  el.textContent = acronyms[current];

  setInterval(() => {
    el.style.opacity = '0';
    setTimeout(() => {
      current = (current + 1) % acronyms.length;
      el.textContent = acronyms[current];
      el.style.opacity = '1';
    }, 500);
  }, 10000);
</script>
