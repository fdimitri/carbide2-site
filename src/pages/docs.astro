---
import Base from '@/layouts/Base.astro';
import Button from '@/components/ui/Button.astro';
---

<Base title="Docs — CARB/IDE2" description="CARB/IDE2 documentation lives at docs.carbidecore.online.">
  <section class="container-narrow py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-carbide-amber">// docs</p>
    <h1 class="mt-2 font-mono text-3xl text-carbide-text">Docs live at docs.carbidecore.online.</h1>
    <p class="mt-4 text-carbide-muted">
      The canonical CARB/IDE2 documentation now lives on the dedicated docs site.
      Use that for architecture, API, deployment, and contributor guides.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <Button href="https://docs.carbidecore.online" external>
        Open the docs site →
      </Button>
      <Button href="https://github.com/fdimitri/carbide2-docs" external variant="ghost">
        Docs source on GitHub
      </Button>
    </div>
  </section>
</Base>
