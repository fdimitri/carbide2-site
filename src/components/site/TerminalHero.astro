---
// CSS-animated *fake* terminal hero.
// NOTE: This is intentionally NOT a real shell. Exposing a live PTY to anonymous
// internet visitors would be reckless. When/if a sandboxed public demo backend
// exists, swap the static `<ol>` below for an xterm.js island that connects to it.
const lines = [
  { prompt: 'frankd@control', cmd: 'kubectl get pods -n ws-demo', delay: 0 },
  { out: 'NAME                    READY   STATUS    RESTARTS   AGE', delay: 1.2 },
  { out: 'ws-demo-6d8f9b-xq2kp   3/3     Running   0          4m', delay: 1.4 },
  { prompt: 'frankd@control', cmd: 'carbide open demo --attach', delay: 3.0 },
  { out: '↳ joined workspace ws-demo  (alice, bob also here)', delay: 4.5 },
  { prompt: 'frankd@ws-demo', cmd: 'git log --oneline -3', delay: 6.0 },
  { out: 'a3f1c2e refactor: extract worker into submodule', delay: 7.0 },
  { out: '9b82dd1 feat: VFS inotify watcher', delay: 7.2 },
  { out: '4e07fa0 fix(auth): workspace token exchange', delay: 7.4 },
];
---

<div
  class="relative overflow-hidden rounded-lg border border-carbide-line bg-carbide-surface shadow-glow"
  role="img"
  aria-label="Animated illustration of a CARB/IDE2 terminal session"
>
  <div class="flex items-center gap-2 border-b border-carbide-line bg-carbide-panel px-4 py-2 font-mono text-xs text-carbide-muted">
    <span class="h-3 w-3 rounded-full bg-carbide-red/70"></span>
    <span class="h-3 w-3 rounded-full bg-carbide-amber/70"></span>
    <span class="h-3 w-3 rounded-full bg-carbide-green/70"></span>
    <span class="ml-3">frankd@CARBIDE-WS3  ~</span>
  </div>
  <ol class="terminal m-0 list-none space-y-1 p-5 font-mono text-sm leading-relaxed">
    {lines.map((line) => (
      <li class="term-line" style={`--delay:${line.delay}s`}>
        {line.cmd ? (
          <>
            <span class="text-carbide-greenDark">{line.prompt}</span>
            <span class="text-carbide-muted"> $ </span>
            <span class="text-carbide-text">{line.cmd}</span>
          </>
        ) : (
          <span class="text-carbide-muted">{line.out}</span>
        )}
      </li>
    ))}
    <li class="term-line" style="--delay:7.8s">
      <span class="text-carbide-greenDark">frankd@ws-demo</span>
      <span class="text-carbide-muted"> $ </span>
      <span class="inline-block h-4 w-2 translate-y-0.5 bg-carbide-green animate-cursor-blink"></span>
    </li>
  </ol>

  <div class="pointer-events-none absolute inset-0 bg-grid bg-[length:24px_24px] opacity-[0.06]"></div>
</div>

<style>
  .terminal .term-line {
    opacity: 0;
    transform: translateY(2px);
    animation: term-in 0.4s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }
  @keyframes term-in {
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .terminal .term-line { opacity: 1; transform: none; animation: none; }
  }
</style>
